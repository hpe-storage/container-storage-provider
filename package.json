{
  "name": "hpe-csp-api-spec",
  "version": "0.0.0",
  "private": true,
  "description": "Contract-first OpenAPI source and tooling for the HPE Container Storage Provider (CSP) API.",
  "scripts": {
    "bootstrap": "swagger2openapi nimble-storage/nimble-csp-api-swagger-v2.yaml -o openapi/openapi.yaml --yaml",
    "lint": "redocly lint nimble-csp-api",
    "bundle": "npm run bundle:yaml && npm run bundle:json",
    "bundle:yaml": "redocly bundle nimble-csp-api -o nimble-storage/nimble-csp-api-openapi.yaml",
    "bundle:json": "redocly bundle nimble-csp-api -o nimble-storage/nimble-csp-api-openapi.json",
    "build": "npm run lint && npm run bundle",
    "preview": "redocly build-docs nimble-csp-api -o csp-api-preview.html"
  },
  "devDependencies": {
    "@redocly/cli": "^2.37.0",
    "swagger2openapi": "^7.0.8"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.5.0"
  }
}
